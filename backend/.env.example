NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/telegram-ai-bot-platform

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=30d

# Frontend URL
FRONTEND_URL=http://localhost:3001

# AI Model Configuration (Your Custom Model)
AI_MODEL_ENDPOINT=http://localhost:5000/api/chat
AI_MODEL_NAME=custom-ai-bot
AI_MODEL_API_KEY=your-ai-model-api-key
AI_MAX_TOKENS=2048

# Telegram (Optional - for bot notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Stripe (Optional - for payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100